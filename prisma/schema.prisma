generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  PURCHASE_MANAGER
  ACCOUNTS_MANAGER
  INWARDS_CLERK
  OUTWARDS_CLERK
}

enum TransactionType {
  INWARD
  OUTWARD
  TRANSFER
  ADJUSTMENT
}

enum SerialStatus {
  IN_STOCK
  SOLD
  RETURNED
  DAMAGED
  RGP_OUT
  TRANSFERRED
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT_TO_VENDOR
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum BillStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  DISPUTED
}

enum PaymentMode {
  CASH
  CHEQUE
  NEFT
  RTGS
  UPI
  CREDIT_ADJUSTMENT
}

enum ExpenseCategory {
  DELIVERY
  TRANSPORT
  SHOP_MAINTENANCE
  UTILITIES
  SALARY_ADVANCE
  FOOD_TEA
  STATIONERY
  MISCELLANEOUS
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum CustomerType {
  WALK_IN
  REGULAR
  DEALER
}

enum InvoiceStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum IssueType {
  QUALITY
  SHORTAGE
  DAMAGE
  WRONG_ITEM
  BILLING_ERROR
  DELIVERY_DELAY
  OTHER
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProductCondition {
  NEW
  REFURBISHED_EXCELLENT
  REFURBISHED_GOOD
  REFURBISHED_FAIR
  DAMAGED
}

enum ProductType {
  BICYCLE
  SPARE_PART
  ACCESSORY
  BOX_PIECE
  WIP
  FINISHED_GOOD
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role
  accessCode    String    @unique
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions  InventoryTransaction[]
  stockCounts   StockCount[]

  createdPOs       PurchaseOrder[]  @relation("POCreatedBy")
  approvedPOs      PurchaseOrder[]  @relation("POApprovedBy")
  recordedPayments VendorPayment[]  @relation("PaymentRecordedBy")
  recordedExpenses Expense[]        @relation("ExpenseRecordedBy")
  recordedCustomerPayments CustomerPayment[] @relation("CustomerPaymentRecordedBy")
  createdIssues    VendorIssue[]    @relation("IssueCreatedBy")
  approvedStockCounts StockCount[] @relation("StockCountApprovedBy")
  verifiedDeliveries  Delivery[]   @relation("DeliveryVerifiedBy")
  uploadedStatements  BankStatement[] @relation("StatementUploader")

  // Service tickets


  // Service jobs


  // Transfer orders
  createdTransfers  TransferOrder[]     @relation("TransferCreatedBy")
  reviewedTransfers TransferOrder[]     @relation("TransferReviewedBy")

  // Second-hand cycles
  createdSecondHand SecondHandCycle[]   @relation("SecondHandCreatedBy")

  // Inbound shipments
  createdInboundShipments  InboundShipment[] @relation("InboundCreatedBy")
  deliveredInboundShipments InboundShipment[] @relation("InboundDeliveredBy")

  // Pre-bookings
  createdPreBookings PreBooking[] @relation("PreBookingCreatedBy")
}

model Category {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String?
  parentId      String?
  parent        Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children      Category[] @relation("CategoryTree")
  movingLevel   String    @default("NORMAL") // FAST, NORMAL, SLOW
  reorderLevel  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products      Product[]
}

model Brand {
  id            String    @id @default(cuid())
  name          String    @unique
  contactName   String?
  contactPhone  String?
  whatsappNumber String?
  cdTermsDays   Int?      // Cash Discount terms in days
  cdPercentage  Float?    // Cash Discount percentage
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products      Product[]
  leadTime      BrandLeadTime?
  inboundShipments InboundShipment[]
  preBookings   PreBooking[]
}

model Product {
  id            String         @id @default(cuid())
  sku           String         @unique
  name          String
  description   String?
  zohoItemId    String?        @unique // Zoho Books item_id for sync
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  brandId       String
  brand         Brand          @relation(fields: [brandId], references: [id])
  type          ProductType    @default(SPARE_PART)
  status        ProductStatus  @default(ACTIVE)
  condition     ProductCondition @default(NEW)

  // Pricing
  costPrice     Float          @default(0)
  sellingPrice  Float          @default(0)
  mrp           Float          @default(0)
  gstRate       Float          @default(18)
  hsnCode       String?

  // Stock
  currentStock  Int            @default(0)
  minStock      Int            @default(0)
  maxStock      Int            @default(0)
  reorderLevel  Int            @default(0)
  reorderQty    Int            @default(0)

  // Bicycle specific
  size          String?        // For bicycles: 16", 20", 24", 26", etc.
  color         String?
  imageUrls     String[]       // Array of image URLs
  tags          String[]       // Condition tags, custom tags

  binId         String?
  bin           Bin?           @relation(fields: [binId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  transactions  InventoryTransaction[]
  stockCounts   StockCountItem[]
  serialItems   SerialItem[]
  purchaseOrderItems PurchaseOrderItem[]
  transferOrderItems TransferOrderItem[]
  inboundLineItems InboundLineItem[]

  @@index([status])
  @@index([categoryId])
  @@index([brandId])
  @@index([type])
  @@index([status, type])
  @@index([status, categoryId])
  @@index([status, brandId])
  @@index([status, currentStock])
  @@index([sku])
  @@index([name])
}

model SerialItem {
  id            String        @id @default(cuid())
  serialCode    String        @unique  // Format: {SKU}-{sequence} e.g. "HRO-MTB26-0001"
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  status        SerialStatus  @default(IN_STOCK)
  condition     ProductCondition @default(NEW)

  // Location
  binId         String?
  bin           Bin?          @relation(fields: [binId], references: [id])

  // Tracking
  batchNo       String?       // Inward batch reference
  invoiceNo     String?       // Purchase invoice
  receivedAt    DateTime      @default(now())
  soldAt        DateTime?
  customerName  String?
  saleInvoiceNo String?

  // Barcode
  barcodeData   String?       // Encoded barcode string (= serialCode by default)
  barcodeFormat String        @default("CODE128") // CODE128, QR, EAN13

  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  transactionItems SerialTransactionItem[]

  @@index([productId])
  @@index([status])
  @@index([binId])
}

model SerialTransactionItem {
  id              String              @id @default(cuid())
  serialItemId    String
  serialItem      SerialItem          @relation(fields: [serialItemId], references: [id])
  transactionId   String
  transaction     InventoryTransaction @relation(fields: [transactionId], references: [id])
  createdAt       DateTime            @default(now())

  @@index([serialItemId])
  @@index([transactionId])
}

model Bin {
  id            String    @id @default(cuid())
  code          String    @unique  // e.g., "A-01-03" (Aisle-Rack-Shelf)
  name          String
  location      String    // "Store" or "Warehouse"
  zone          String?   // Zone within location
  capacity      Int?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products      Product[]
  serialItems   SerialItem[]
  stockCounts   StockCount[]
  transfersFrom TransferOrderItem[] @relation("TransferFromBin")
  transfersTo   TransferOrderItem[] @relation("TransferToBin")
  secondHandCycles SecondHandCycle[] @relation("SecondHandBin")
}

model InventoryTransaction {
  id            String           @id @default(cuid())
  type          TransactionType
  productId     String
  product       Product          @relation(fields: [productId], references: [id])
  quantity      Int
  previousStock Int
  newStock      Int

  // Reference
  referenceNo   String?          // PO number, Invoice number, etc.
  notes         String?

  // Who
  userId        String
  user          User             @relation(fields: [userId], references: [id])

  // RGP (Returnable Gate Pass)
  isRgp         Boolean          @default(false)
  rgpReturnDate DateTime?
  rgpReturned   Boolean          @default(false)

  createdAt     DateTime         @default(now())

  serialItems   SerialTransactionItem[]

  @@index([productId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([type, createdAt])
  @@index([productId, type])
}

model StockCount {
  id              String           @id @default(cuid())
  countNo         String?          @unique // Auto: SC-YYYYMM-NNNN
  title           String           // "Weekly Audit - Week 15"
  assignedToId    String
  assignedTo      User             @relation(fields: [assignedToId], references: [id])
  binId           String?
  bin             Bin?             @relation(fields: [binId], references: [id])
  status          String           @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, APPROVED, REJECTED
  dueDate         DateTime
  completedAt     DateTime?
  approvedById    String?
  approvedBy      User?            @relation("StockCountApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?
  notes           String?
  productType     String?          // Filter: BICYCLE, SPARE_PART, ACCESSORY, or null=all
  location        String?          // Location-level scope: "BCH-GF", "BCH-FF", etc. Null = single bin or all
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  items           StockCountItem[]
}

model StockCountItem {
  id              String     @id @default(cuid())
  stockCountId    String
  stockCount      StockCount @relation(fields: [stockCountId], references: [id])
  productId       String
  product         Product    @relation(fields: [productId], references: [id])
  systemQty       Int
  countedQty      Int?
  variance        Int?
  suggestedBrand  String?    // Staff suggests brand for "Imported" items
  notes           String?
  countedAt       DateTime?
}

model Vendor {
  id              String          @id @default(cuid())
  name            String          @unique
  code            String          @unique
  gstin           String?
  pan             String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  pincode         String?
  phone           String?
  email           String?
  whatsappNumber  String?
  paymentTermDays Int             @default(30)
  creditLimit     Float           @default(0)
  cdTermsDays     Int?
  cdPercentage    Float?
  openingBalance  Float           @default(0) // As of 2026-04-01
  isActive        Boolean         @default(true)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  contacts            VendorContact[]
  purchaseOrders      PurchaseOrder[]
  bills               VendorBill[]
  payments            VendorPayment[]
  credits             VendorCredit[]
  issues              VendorIssue[]
  suggestedBankTxns   BankTransaction[] @relation("SuggestedVendorTxn")
  confirmedBankTxns   BankTransaction[] @relation("ConfirmedVendorTxn")

  @@index([name])
}

model VendorContact {
  id          String   @id @default(cuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  name        String
  designation String?
  phone       String?
  email       String?
  whatsapp    String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vendorId])
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  poNumber        String              @unique
  vendorId        String
  vendor          Vendor              @relation(fields: [vendorId], references: [id])
  status          POStatus            @default(DRAFT)
  subtotal        Float               @default(0)
  gstTotal        Float               @default(0)
  grandTotal      Float               @default(0)
  orderDate       DateTime            @default(now())
  expectedDate    DateTime?
  approvedById    String?
  approvedBy      User?               @relation("POApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  createdById     String
  createdBy       User                @relation("POCreatedBy", fields: [createdById], references: [id])
  notes           String?
  deliveryAddress String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  items           PurchaseOrderItem[]
  bills           VendorBill[]

  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  receivedQty     Int           @default(0)
  unitPrice       Float
  gstRate         Float         @default(18)
  amount          Float
  createdAt       DateTime      @default(now())

  @@index([purchaseOrderId])
  @@index([productId])
}

model VendorBill {
  id               String         @id @default(cuid())
  vendorId         String
  vendor           Vendor         @relation(fields: [vendorId], references: [id])
  purchaseOrderId  String?
  purchaseOrder    PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  billNo           String
  billDate         DateTime
  dueDate          DateTime
  amount           Float
  paidAmount       Float          @default(0)
  status           BillStatus     @default(PENDING)
  lastFollowedUp   DateTime?
  nextFollowUpDate DateTime?
  followUpNotes    String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  payments           VendorPayment[]
  issues             VendorIssue[]
  suggestedBankTxns  BankTransaction[] @relation("SuggestedBillTxn")

  @@unique([vendorId, billNo])
  @@index([vendorId])
  @@index([status])
  @@index([dueDate])
}

model VendorPayment {
  id                String        @id @default(cuid())
  vendorId          String
  vendor            Vendor        @relation(fields: [vendorId], references: [id])
  billId            String?
  bill              VendorBill?   @relation(fields: [billId], references: [id])
  amount            Float
  cdDiscountAmount  Float         @default(0) // Cash discount applied
  paymentMode       PaymentMode
  paymentDate       DateTime
  referenceNo       String?
  notes             String?
  creditId          String?
  credit            VendorCredit? @relation(fields: [creditId], references: [id])
  recordedById      String
  recordedBy        User          @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  createdAt         DateTime      @default(now())

  @@index([vendorId])
  @@index([billId])
  @@index([paymentDate])
}

model VendorCredit {
  id            String          @id @default(cuid())
  vendorId      String
  vendor        Vendor          @relation(fields: [vendorId], references: [id])
  creditNoteNo  String
  amount        Float
  usedAmount    Float           @default(0)
  reason        String?
  creditDate    DateTime
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  payments      VendorPayment[]

  @@unique([vendorId, creditNoteNo])
  @@index([vendorId])
}

model Expense {
  id            String          @id @default(cuid())
  date          DateTime
  amount        Float
  category      ExpenseCategory
  description   String
  paidBy        String
  paymentMode   PaymentMode
  referenceNo   String?
  receiptUrl    String?
  notes         String?
  recordedById  String
  recordedBy    User            @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([date])
  @@index([category])
  @@index([recordedById])
}

// ─── BANK STATEMENT RECONCILIATION ───

enum BankTxnType {
  CREDIT
  DEBIT
}

enum BankTxnMatchStatus {
  UNMATCHED
  MATCHED
  FLAGGED
  EXPENSE
  IGNORED
}

model BankStatement {
  id              String            @id @default(cuid())
  bank            String            // HDFC, ICICI
  accountNumber   String?
  fileName        String
  fromDate        DateTime?
  toDate          DateTime?
  totalCredits    Float             @default(0)
  totalDebits     Float             @default(0)
  txnCount        Int               @default(0)
  matchedCount    Int               @default(0)
  flaggedCount    Int               @default(0)
  uploadedById    String
  uploadedBy      User              @relation("StatementUploader", fields: [uploadedById], references: [id])
  createdAt       DateTime          @default(now())

  transactions    BankTransaction[]

  @@index([createdAt])
}

model BankTransaction {
  id              String              @id @default(cuid())
  statementId     String
  statement       BankStatement       @relation(fields: [statementId], references: [id], onDelete: Cascade)
  date            DateTime
  description     String
  reference       String?
  amount          Float
  type            BankTxnType         // CREDIT or DEBIT
  balance         Float?
  matchStatus     BankTxnMatchStatus  @default(UNMATCHED)
  flagReason      String?
  // AI-suggested matches
  suggestedVendorId   String?
  suggestedVendor     Vendor?         @relation("SuggestedVendorTxn", fields: [suggestedVendorId], references: [id])
  suggestedBillId     String?
  suggestedBill       VendorBill?     @relation("SuggestedBillTxn", fields: [suggestedBillId], references: [id])
  suggestedCategory   String?         // For expenses
  confidence          Float?          // AI match confidence 0-1
  // Confirmed matches
  confirmedVendorId   String?
  confirmedVendor     Vendor?         @relation("ConfirmedVendorTxn", fields: [confirmedVendorId], references: [id])
  confirmedPaymentId  String?
  confirmedExpenseId  String?
  processedAt         DateTime?
  createdAt           DateTime        @default(now())

  @@index([statementId])
  @@index([matchStatus])
  @@index([date])
}

model ZohoConfig {
  id                   String    @id @default("singleton")
  clientId             String?
  clientSecret         String?
  refreshToken         String?
  accessToken          String?
  accessTokenExpiresAt DateTime?
  organizationId       String?
  organizationName     String?
  isConnected          Boolean   @default(false)
  lastSyncAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ZakyaConfig {
  id                   String    @id @default("singleton")
  clientId             String?
  clientSecret         String?
  refreshToken         String?
  accessToken          String?
  accessTokenExpiresAt DateTime?
  organizationId       String?
  organizationName     String?
  isConnected          Boolean   @default(false)
  lastSyncAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ZohoInventoryConfig {
  id                   String    @id @default("singleton")
  clientId             String?
  clientSecret         String?
  refreshToken         String?
  accessToken          String?
  accessTokenExpiresAt DateTime?
  organizationId       String?
  organizationName     String?
  isConnected          Boolean   @default(false)
  lastSyncAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model SyncLog {
  id          String   @id @default(cuid())
  syncType    String   // items, contacts, invoices, bills, all
  status      String   // running, success, partial, failed
  totalItems  Int      @default(0)
  synced      Int      @default(0)
  failed      Int      @default(0)
  errors      String?  // JSON array of error messages
  startedAt   DateTime @default(now())
  completedAt DateTime?
  triggeredBy String?  // userId

  @@index([syncType])
  @@index([startedAt])
}

// ---- Customers & Receivables ----

model Customer {
  id            String         @id @default(cuid())
  name          String
  phone         String?
  email         String?
  address       String?
  type          CustomerType   @default(WALK_IN)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  invoices      CustomerInvoice[]
  payments      CustomerPayment[]

  @@index([name])
  @@index([phone])
}

model CustomerInvoice {
  id            String         @id @default(cuid())
  customerId    String
  customer      Customer       @relation(fields: [customerId], references: [id])
  invoiceNo     String         @unique
  invoiceDate   DateTime
  dueDate       DateTime
  amount        Float
  paidAmount    Float          @default(0)
  status        InvoiceStatus  @default(PENDING)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  payments      CustomerPayment[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model CustomerPayment {
  id            String           @id @default(cuid())
  customerId    String
  customer      Customer         @relation(fields: [customerId], references: [id])
  invoiceId     String?
  invoice       CustomerInvoice? @relation(fields: [invoiceId], references: [id])
  amount        Float
  paymentMode   PaymentMode
  paymentDate   DateTime
  referenceNo   String?
  notes         String?
  recordedById  String
  recordedBy    User             @relation("CustomerPaymentRecordedBy", fields: [recordedById], references: [id])
  createdAt     DateTime         @default(now())

  @@index([customerId])
  @@index([invoiceId])
  @@index([paymentDate])
}

// ---- Vendor Issues ----

model VendorIssue {
  id            String         @id @default(cuid())
  vendorId      String
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  issueNo       String         @unique // ISS-YYYYMM-NNNN
  issueType     IssueType
  description   String
  status        IssueStatus    @default(OPEN)
  priority      IssuePriority  @default(MEDIUM)
  billId        String?
  bill          VendorBill?    @relation(fields: [billId], references: [id])
  resolution    String?
  resolvedAt    DateTime?
  createdById   String
  createdBy     User           @relation("IssueCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([vendorId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

enum DeliveryStatus {
  PENDING
  VERIFIED
  WALK_OUT
  SCHEDULED
  OUT_FOR_DELIVERY
  DELIVERED
  FLAGGED
  PREBOOKED
  PACKED
  SHIPPED
  IN_TRANSIT
}

model Delivery {
  id              String          @id @default(cuid())
  invoiceNo       String          @unique
  zohoInvoiceId   String?
  invoiceDate     DateTime
  invoiceAmount   Float

  customerName    String
  customerPhone   String?
  customerAddress String?
  customerArea    String?
  customerPincode String?

  status          DeliveryStatus  @default(PENDING)
  verifiedAt      DateTime?
  verifiedById    String?
  verifiedBy      User?           @relation("DeliveryVerifiedBy", fields: [verifiedById], references: [id])

  scheduledDate   DateTime?
  dispatchedAt    DateTime?
  deliveredAt     DateTime?

  expectedReadyDate DateTime?
  prebookNotes    String?

  flagReason      String?
  flaggedAt       DateTime?
  flagResolvedAt  DateTime?
  flagResolvedBy  String?

  invoiceType     String?           // "SALES" | "SERVICE" — null = not yet tagged
  salesPerson     String?
  lineItems       Json?
  notes           String?
  deliveryNotes   String?

  // WhatsApp tracking
  whatsAppScheduledSent   Boolean  @default(false)
  whatsAppDispatchedSent  Boolean  @default(false)
  whatsAppDeliveredSent   Boolean  @default(false)
  freeAccessories         String?

  // Outstation delivery
  isOutstation            Boolean  @default(false)
  courierName             String?
  courierTrackingNo       String?
  courierCost             Float?
  vehicleNo               String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([invoiceDate])
  @@index([customerArea])
  @@index([scheduledDate])
}

model AlertConfig {
  id              String   @id @default("singleton")
  redFlagPhones   String?
  googleReviewLink String?
  updatedAt       DateTime @updatedAt
}

// ─── Zoho Pull Preview (approval gate) ───────────────────────

model ZohoPullPreview {
  id            String    @id @default(cuid())
  pullId        String
  entityType    String    // "contact", "item", "bill", "invoice"
  action        String    @default("new")
  zohoId        String
  data          Json
  localMatch    Json?
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedAt    DateTime?
  reviewedById  String?
  createdAt     DateTime  @default(now())

  @@index([pullId])
  @@index([entityType])
  @@index([status])
}

model ZohoPullLog {
  id              String    @id @default(cuid())
  pullId          String    @unique
  status          String    @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, REJECTED, PARTIAL
  contactsNew     Int       @default(0)
  itemsNew        Int       @default(0)
  billsNew        Int       @default(0)
  invoicesNew     Int       @default(0)
  errors          String?
  apiCallsUsed    Int       @default(0)
  createdAt       DateTime  @default(now())
  approvedAt      DateTime?

  @@index([status])
  @@index([createdAt])
}

// ─── Second-Hand Cycles (Exchange inventory) ───────────────────────

model SecondHandCycle {
  id              String    @id @default(cuid())
  sku             String    @unique  // Auto: SH-0001
  name            String               // e.g., "Hero Sprint 26"
  condition       String               // EXCELLENT, GOOD, FAIR, SCRAP
  status          String    @default("IN_STOCK") // IN_STOCK, SOLD
  costPrice       Float               // Exchange price
  sellingPrice    Float?              // Set by admin after service
  photoUrl        String              // Primary image URL (thumbnail)
  photoUrls       String[]            // All image URLs including primary

  // Source (who traded in)
  customerName    String
  customerPhone   String?
  zohoInvoiceNo   String?             // New cycle sale invoice
  zohoItemId      String?             // Zoho Inventory item_id after push

  // Location
  binId           String?
  bin             Bin?      @relation("SecondHandBin", fields: [binId], references: [id])

  // Sale details
  soldAt          DateTime?
  soldToName      String?
  soldToPhone     String?
  soldInvoiceNo   String?

  notes           String?
  isArchived      Boolean   @default(false)

  createdById     String
  createdBy       User      @relation("SecondHandCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([sku])
  @@index([createdAt])
}

// ─── Transfer Orders (Multi-item bin transfers) ───────────────────────

enum TransferOrderStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model TransferOrder {
  id            String              @id @default(cuid())
  orderNo       String              @unique // Auto: TRF-YYYYMM-NNNN
  status        TransferOrderStatus @default(PENDING)
  notes         String?

  createdById   String
  createdBy     User                @relation("TransferCreatedBy", fields: [createdById], references: [id])
  reviewedById  String?
  reviewedBy    User?               @relation("TransferReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  rejectionNote String?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  items         TransferOrderItem[]

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model TransferOrderItem {
  id              String        @id @default(cuid())
  transferOrderId String
  transferOrder   TransferOrder @relation(fields: [transferOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  fromBinId       String
  fromBin         Bin           @relation("TransferFromBin", fields: [fromBinId], references: [id])
  toBinId         String
  toBin           Bin           @relation("TransferToBin", fields: [toBinId], references: [id])
  createdAt       DateTime      @default(now())

  @@index([transferOrderId])
  @@index([productId])
}

// ─── Inbound Tracking (Brand Deliveries & Pre-booking) ───────────────────────

model BrandLeadTime {
  id        String   @id @default(cuid())
  brandId   String   @unique
  brand     Brand    @relation(fields: [brandId], references: [id])
  leadDays  Int      @default(7)
  updatedAt DateTime @updatedAt
}

enum InboundShipmentStatus {
  IN_TRANSIT
  DELIVERED
  PARTIALLY_DELIVERED
}

model InboundShipment {
  id                    String                @id @default(cuid())
  shipmentNo            String                @unique // Auto: IB-YYYYMM-0001
  brandId               String
  brand                 Brand                 @relation(fields: [brandId], references: [id])
  billNo                String                // Brand's invoice number (from image)
  billImageUrl          String                @db.Text // Base64 photo of paper bill
  billPdfUrl            String?               // Supabase Storage URL for uploaded PDF
  billDate              DateTime
  expectedDeliveryDate  DateTime
  status                InboundShipmentStatus @default(IN_TRANSIT)
  totalAmount           Float
  totalItems            Int
  deliveredAt           DateTime?
  deliveredById         String?
  deliveredBy           User?                 @relation("InboundDeliveredBy", fields: [deliveredById], references: [id])
  notes                 String?
  createdById           String
  createdBy             User                  @relation("InboundCreatedBy", fields: [createdById], references: [id])
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  lineItems             InboundLineItem[]
  preBookings           PreBooking[]

  @@index([status])
  @@index([brandId])
  @@index([billNo])
  @@index([expectedDeliveryDate])
  @@index([createdAt])
}

model InboundLineItem {
  id                     String            @id @default(cuid())
  shipmentId             String
  shipment               InboundShipment   @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  productName            String            // As read from bill image
  productId              String?           // Matched to existing product
  product                Product?          @relation(fields: [productId], references: [id])
  sku                    String?
  quantity               Int
  rate                   Float
  amount                 Float
  hsn                    String?
  isDelivered            Boolean           @default(false)
  deliveredQty           Int?
  preBookedCustomerName  String?
  preBookedCustomerPhone String?
  preBookedInvoiceNo     String?
  whatsAppSent           Boolean           @default(false)
  notes                  String?

  preBooking             PreBooking?       @relation("PreBookingLineItem")

  @@index([shipmentId])
  @@index([productId])
}

enum PreBookingStatus {
  WAITING
  MATCHED
  FULFILLED
  CANCELLED
}

model PreBooking {
  id                    String            @id @default(cuid())
  customerName          String
  customerPhone         String?
  zohoInvoiceNo         String
  productName           String            // What cycle they booked
  brandId               String?
  brand                 Brand?            @relation(fields: [brandId], references: [id])
  status                PreBookingStatus  @default(WAITING)
  matchedShipmentId     String?
  matchedShipment       InboundShipment?  @relation(fields: [matchedShipmentId], references: [id])
  matchedLineItemId     String?           @unique
  matchedLineItem       InboundLineItem?  @relation("PreBookingLineItem", fields: [matchedLineItemId], references: [id])
  salesPerson           String?
  expectedDate          DateTime?
  fulfilledAt           DateTime?
  createdById           String
  createdBy             User              @relation("PreBookingCreatedBy", fields: [createdById], references: [id])
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([status])
  @@index([brandId])
  @@index([matchedShipmentId])
  @@index([createdAt])
}
